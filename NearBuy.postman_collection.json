{
  "info": {
    "name": "NearBuy Full Backend APIs",
    "_postman_id": "nearbuy-full",
    "description": "Complete E-commerce Backend APIs with Cart, Order, Address, Payment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [

    {
      "name": "Auth APIs",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },

    {
      "name": "Category APIs",
      "item": [
        {
          "name": "Add Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\"\n}"
            },
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          }
        }
      ]
    },

    {
      "name": "Product APIs",
      "item": [
        {
          "name": "Add Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"iPhone\",\n  \"description\": \"Apple phone\",\n  \"price\": 80000,\n  \"stock\": 10,\n  \"categoryId\": 1\n}"
            },
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Get Products (Search + Filter + Sort)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products?keyword=iphone&min=1000&max=100000&page=0&size=5&sort=price,desc"
          }
        }
      ]
    },

    {
      "name": "Cart APIs",
      "item": [
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 1,\n  \"quantity\": 2\n}"
            },
            "url": "{{baseUrl}}/cart"
          }
        },
        {
          "name": "View Cart",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/cart"
          }
        },
        {
          "name": "Remove from Cart",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/cart/items/1"
          }
        }
      ]
    },

    {
      "name": "Address APIs",
      "item": [
        {
          "name": "Add Address",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"street\": \"MG Road\",\n  \"city\": \"Bangalore\",\n  \"state\": \"Karnataka\",\n  \"zipCode\": \"560001\",\n  \"country\": \"India\"\n}"
            },
            "url": "{{baseUrl}}/address"
          }
        },
        {
          "name": "Get Addresses",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/address"
          }
        }
      ]
    },

    {
      "name": "Order APIs",
      "item": [
        {
          "name": "Checkout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"addressId\": 1\n}"
            },
            "url": "{{baseUrl}}/orders/checkout"
          }
        },
        {
          "name": "Get Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/orders/1/status?status=SHIPPED"
          }
        }
      ]
    },

    {
      "name": "Payment APIs",
      "item": [
        {
          "name": "Make Payment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/payments/1?successful=true"
          }
        }
      ]
    }

  ]
}
